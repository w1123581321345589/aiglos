# Aiglos environment variables
# Copy to .env and fill in values

# ── Required for Pro/Enterprise features ───────────────────────────────────
AIGLOS_KEY=ak_live_your_key_here          # Pro/Enterprise API key from aiglos.dev

# ── Optional configuration ──────────────────────────────────────────────────
AIGLOS_SIGNING_KEY=                        # HMAC signing key (default: session_id)
AIGLOS_PRIVATE_KEY=                        # RSA-2048 private key path for Pro artifacts
AIGLOS_OBS_DB=~/.aiglos/observation.db     # Observation graph database path
AIGLOS_LOG_LEVEL=WARNING                   # DEBUG | INFO | WARNING | ERROR
AIGLOS_MODE=block                          # block | warn | audit
AIGLOS_FREE_LIMIT=10000                    # Monthly tool call limit (free tier)
AIGLOS_ENDPOINT=https://telemetry.aiglos.dev  # Cloud telemetry endpoint

# ── Subprocess interception ─────────────────────────────────────────────────
AIGLOS_INTERCEPT_SUBPROCESS=false         # Enable subprocess surface (set true to activate)
AIGLOS_INTERCEPT_HTTP=false               # Enable HTTP surface (set true to activate)
AIGLOS_ALLOW_HTTP=                         # Comma-separated allowed HTTP domains
AIGLOS_APPROVAL_TIMEOUT=30                # Tier 3 webhook approval timeout (seconds)
AIGLOS_HMAC_SECRET=                        # Webhook HMAC secret for Tier 3 approvals

# ── Autoresearch (optional) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=                         # Required for autoresearch two-loop system

# ── Deployment integrations (optional) ─────────────────────────────────────
# Netlify functions
STRIPE_SECRET_KEY=sk_live_xxx             # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_xxx           # Stripe webhook signing secret
STRIPE_PAYG_PRICE_ID=price_xxx            # Metered usage price ID
RESEND_API_KEY=re_xxx                     # Resend email API key (signup notifications)
SUPABASE_URL=https://xxx.supabase.co      # Supabase project URL (key storage)
SUPABASE_ANON_KEY=eyJ...                  # Supabase anon key
